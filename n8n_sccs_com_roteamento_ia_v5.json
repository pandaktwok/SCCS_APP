    {
      "parameters": {
        "jsCode": "const returnItems = [];\nfor (const item of $input.all()) {\n  if (item.binary) {\n    for (const key of Object.keys(item.binary)) {\n      if (key.startsWith('attachment_')) {\n        returnItems.push({\n          json: { ...item.json, source_attachment: key },\n          binary: { attachment_0: item.binary[key] }\n        });\n      }\n    }\n  }\n}\nreturn returnItems;"
      },
