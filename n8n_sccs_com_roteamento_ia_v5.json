    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst now = new Date();\nnow.setHours(now.getHours() - 3); // Fuso do Brasil para reset\nconst todayStr = now.toISOString().split('T')[0];\n\nif (staticData.lastDate !== todayStr) {\n  staticData.lastDate = todayStr;\n  staticData.dailyCount = 0;\n}\n\nlet results = [];\nfor (const item of $input.all()) {\n  staticData.dailyCount += 1;\n  results.push({\n    json: { ...item.json, dailyDataCount: staticData.dailyCount },\n    binary: item.binary\n  });\n}\n\nreturn results;"
      },
