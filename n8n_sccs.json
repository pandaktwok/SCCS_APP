    {
      "parameters": {
        "promptType": "define",
        "text": "=Você é um assistente financeiro. Leia o texto da nota fiscal e extraia stritamente 5 informações em formato JSON: 'fornecedor', 'numero_nota', 'data', 'valor_total' e 'termo_projeto'.\n\nResponda APENAS o JSON bruto, sem blocos de código markdown ou explicações.\nTexto da nota: {{ $json.text }}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        480,
        528
      ],
      "id": "118b907c-a98a-4077-84fb-65976a216cf5",
      "name": "AI Agent"
    },
