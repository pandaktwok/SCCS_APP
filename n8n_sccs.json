        "modelName": "models/gemini-2.5-flash-lite",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [
        480,
        740
      ],
      "id": "c469a96a-0fea-49fb-b4a2-d38383281de7",
      "name": "Google Gemini Chat Model",
      "credentials": {
        "googlePalmApi": {
          "id": "XIPQdJJrcXyc1WjO",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "let results = [];\nlet originalBinary;\ntry {\n  originalBinary = $('Loop').first().binary;\n} catch (e) {\n  try {\n    originalBinary = $items('Loop')[0].binary;\n  } catch(e2) {}\n}\n\nfor (const item of $input.all()) {\n  try {\n    let rawOutput = item.json.output;\n    let cleanText = rawOutput.replace(/```json|```/g, '').trim();\n    let parsedData = JSON.parse(cleanText);\n\n    if (parsedData.valor_total) {\n      let valorSujo = String(parsedData.valor_total).replace(/[^\\d.,-]/g, '');\n      if (valorSujo.includes(',')) {\n        valorSujo = valorSujo.replace(/\\./g, '').replace(',', '.');\n      }\n      parsedData.valor_total = valorSujo;\n    }\n\n    if (parsedData.termo_projeto && parsedData.termo_projeto !== null && parsedData.termo_projeto !== 'null') {\n      let termoLimpo = String(parsedData.termo_projeto).split('/')[0].trim();\n      if (!termoLimpo.toUpperCase().startsWith('T ')) {\n        termoLimpo = 'T ' + termoLimpo;\n      }\n      parsedData.termo_projeto = termoLimpo;\n    } else {\n      parsedData.termo_projeto = 'T 0000';\n    }\n\n    results.push({ \n      json: parsedData,\n      binary: originalBinary \n    });\n  } catch (error) {\n    results.push({ json: { erro: \"Falha na organizacao do JSON\", textoOrigin: item.json.output } });\n  }\n}\n\nreturn results;"
      },
